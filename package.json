  },
  "devDependencies": {
    "@iconify-json/simple-icons": "^1.2.82",
    "@iconify-json/tabler": "^1.2.35",
    "@nuxt/eslint": "^1.15.2",
    "@nuxtjs/plausible": "^3.0.2",
    "@types/node": "^25.8.0",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3"
  }
}
