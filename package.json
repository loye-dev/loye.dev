  },
  "devDependencies": {
    "@iconify-json/simple-icons": "^1.2.87",
    "@iconify-json/tabler": "^1.2.35",
    "@nuxt/eslint": "^1.16.0",
    "@nuxtjs/plausible": "^3.0.2",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "prettier": "^3.9.1",
    "prettier-plugin-tailwindcss": "^0.8.0"
  }
